<Window x:Class="ARNetDiscovery.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:conv="clr-namespace:ARNetDiscovery.Wpf.Converters"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="ARNet Discovery"
        Width="1280" Height="820" MinWidth="1100" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#F6F8FB"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="7" GlassFrameThickness="0" UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <conv:StatusBrushConverter x:Key="StatusBrushConverter" />
        <conv:NullToVisibilityConverter x:Key="NullToVisible" />
        <conv:NullToVisibilityConverter x:Key="NullToCollapsedInvert" Invert="True" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVisible" />
        <conv:BoolToVisibilityConverter x:Key="BoolToCollapsedInvert" Invert="True" />
        <conv:PercentToWidthConverter x:Key="PercentToWidthConverter" />
        <conv:StatusLabelConverter x:Key="StatusLabelConverter" />
        <conv:StringEmptyToVisibilityConverter x:Key="StringEmptyToVisible" />
        <conv:LucideIconConverter x:Key="LucideIconConverter" />

        <Style x:Key="LucidePath" TargetType="Path">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="Stroke" Value="{StaticResource BrushBody}" />
            <Setter Property="StrokeThickness" Value="1.8" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="Fill" Value="Transparent" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#60708A" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="ColumnHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#60708A" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="WindowIconButton" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#53637A" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" CornerRadius="10" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EDF2F7" />
                                <Setter Property="Foreground" Value="#0B1020" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseWindowButton" TargetType="Button" BasedOn="{StaticResource WindowIconButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="Background" Value="#EF4444" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PremiumButton" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#D9E2EE" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#111827" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="18"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F8FBFF" />
                                <Setter Property="BorderBrush" Value="#B8C7D9" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#EEF4FA" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.48" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryWebButton" TargetType="Button" BasedOn="{StaticResource PremiumButton}">
            <Setter Property="BorderBrush" Value="#050B1F" />
            <Setter Property="Background" Value="#050B1F" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="18,0" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#111A33" />
                    <Setter Property="BorderBrush" Value="#111A33" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AccentWebButton" TargetType="Button" BasedOn="{StaticResource PremiumButton}">
            <Setter Property="BorderBrush" Value="#20BCD8" />
            <Setter Property="Background" Value="#28C3DE" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="DarkPillButton" TargetType="Button" BasedOn="{StaticResource PremiumButton}">
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="#23304B" />
            <Setter Property="Foreground" Value="#EAF2FF" />
        </Style>

        <Style x:Key="DeviceRowItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="BorderBrush" Value="#DCE4EF" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Margin="18,14" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F8FBFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F0F5FA" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="#F6F8FB">
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="324" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#FFFFFF" BorderBrush="#DCE4EF" BorderThickness="0,0,0,1" MouseLeftButtonDown="TopChrome_MouseLeftButtonDown">
            <Grid Margin="20,0,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="28" Height="28" CornerRadius="10" Background="#EAF7FB" BorderBrush="#CDECF4" BorderThickness="1">
                        <TextBlock Text="AR" Foreground="#0EA5C4" FontWeight="SemiBold" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="ARNet" FontSize="13" FontWeight="SemiBold" Foreground="#0B1020" Margin="10,0,0,0" VerticalAlignment="Center" />
                    <TextBlock Text=" Discovery" FontSize="13" FontWeight="SemiBold" Foreground="#0EA5C4" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource WindowIconButton}" Click="MinimizeButton_Click" Content="-" />
                    <Button Style="{StaticResource WindowIconButton}" Click="MaximizeButton_Click" Content="□" />
                    <Button Style="{StaticResource CloseWindowButton}" Click="CloseButton_Click" Content="×" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Grid.Column="0" Margin="38,18,20,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Height="38" Background="#FFFFFF" BorderBrush="#D9E2EE" BorderThickness="1" CornerRadius="19" Padding="14,0">
                    <Grid>
                        <Path Style="{StaticResource LucidePath}" Data="{Binding Converter={StaticResource LucideIconConverter}, ConverterParameter=search}" Stroke="#60708A" HorizontalAlignment="Left" />
                        <TextBlock Text="Search name, vendor, IP or MAC" Foreground="#60708A" FontSize="12" Margin="24,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"
                                   Visibility="{Binding FilterText, Converter={StaticResource StringEmptyToVisible}}" />
                        <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" Padding="24,0,0,0" FontSize="12" Height="34" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border CornerRadius="16" Background="#050B1F" Padding="14,7" Margin="0,0,8,0">
                        <TextBlock Text="All" Foreground="White" FontSize="11" FontWeight="SemiBold" />
                    </Border>
                    <Border CornerRadius="16" Background="#FFFFFF" BorderBrush="#D9E2EE" BorderThickness="1" Padding="14,7" Margin="0,0,8,0">
                        <TextBlock Text="Online" Foreground="#40516A" FontSize="11" />
                    </Border>
                    <Border CornerRadius="16" Background="#FFFFFF" BorderBrush="#D9E2EE" BorderThickness="1" Padding="14,7" Margin="0,0,8,0">
                        <TextBlock Text="Expected" Foreground="#40516A" FontSize="11" />
                    </Border>
                    <Border CornerRadius="16" Background="#FFFFFF" BorderBrush="#D9E2EE" BorderThickness="1" Padding="14,7">
                        <TextBlock Text="Offline" Foreground="#40516A" FontSize="11" />
                    </Border>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Border Background="#FFFFFF" BorderBrush="#D9E2EE" BorderThickness="1" CornerRadius="16" Padding="16,12" Width="144" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="DEVICES" Style="{StaticResource ColumnHeader}" />
                            <TextBlock Text="{Binding DiscoveredHosts}" FontSize="24" FontWeight="SemiBold" Foreground="#0B1020" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Background="#FFFFFF" BorderBrush="#D9E2EE" BorderThickness="1" CornerRadius="16" Padding="16,12" Width="144" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="ONLINE" Style="{StaticResource ColumnHeader}" />
                            <TextBlock Text="{Binding OnlineCount}" FontSize="24" FontWeight="SemiBold" Foreground="#08A877" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Background="#FFFFFF" BorderBrush="#D9E2EE" BorderThickness="1" CornerRadius="16" Padding="16,12" Width="144" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="GATEWAYS" Style="{StaticResource ColumnHeader}" />
                            <TextBlock Text="{Binding GatewayCount}" FontSize="24" FontWeight="SemiBold" Foreground="#0EA5C4" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Background="#FFFFFF" BorderBrush="#D9E2EE" BorderThickness="1" CornerRadius="16" Padding="16,12" Width="144">
                        <StackPanel>
                            <TextBlock Text="PROTOCOL" Style="{StaticResource ColumnHeader}" />
                            <TextBlock Text="{Binding IndustrialCandidateCount}" FontSize="24" FontWeight="SemiBold" Foreground="#0B1020" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Border Height="38" Width="210" Background="#FFFFFF" BorderBrush="#D9E2EE" BorderThickness="1" CornerRadius="19" Padding="12,0" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource LucidePath}" Data="{Binding Converter={StaticResource LucideIconConverter}, ConverterParameter=network}" Stroke="#0EA5C4" Width="15" Height="15" />
                            <ComboBox ItemsSource="{Binding Adapters}" SelectedItem="{Binding SelectedAdapter}" DisplayMemberPath="DisplayName" BorderThickness="0" Background="Transparent" Width="170" VerticalAlignment="Center" Margin="8,0,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Height="38" Width="180" Background="#FFFFFF" BorderBrush="#D9E2EE" BorderThickness="1" CornerRadius="19">
                        <Grid>
                            <TextBlock Text="Probe IP/range" Foreground="#60708A" FontSize="11.5" Margin="14,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"
                                       Visibility="{Binding DirectTargetText, Converter={StaticResource StringEmptyToVisible}}" />
                            <TextBox Text="{Binding DirectTargetText, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" Padding="14,0,14,0" FontSize="12" Height="34" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2" Margin="0,16,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <WrapPanel HorizontalAlignment="Right">
                    <Button Style="{StaticResource PremiumButton}" Command="{Binding ProbeTargetCommand}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource LucidePath}" Data="{Binding Converter={StaticResource LucideIconConverter}, ConverterParameter=activity}" Width="14" Height="14" />
                            <TextBlock Text="Probe" Margin="8,0,0,0" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PremiumButton}" Command="{Binding ImportTargetListCommand}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource LucidePath}" Data="{Binding Converter={StaticResource LucideIconConverter}, ConverterParameter=import}" Width="14" Height="14" />
                            <TextBlock Text="Import List" Margin="8,0,0,0" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource AccentWebButton}" Command="{Binding ScanImportedTargetsCommand}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource LucidePath}" Data="{Binding Converter={StaticResource LucideIconConverter}, ConverterParameter=play}" Stroke="White" Width="14" Height="14" />
                            <TextBlock Text="Scan List" Margin="8,0,0,0" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PremiumButton}" Command="{Binding LoadDemoCommand}" Content="Sample" Margin="0,0,8,0" />
                    <Button Style="{StaticResource PremiumButton}" Command="{Binding ExportCsvCommand}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource LucidePath}" Data="{Binding Converter={StaticResource LucideIconConverter}, ConverterParameter=download}" Width="14" Height="14" />
                            <TextBlock Text="Export" Margin="8,0,0,0" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PremiumButton}" Command="{Binding StopCommand}" Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisible}}" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource LucidePath}" Data="{Binding Converter={StaticResource LucideIconConverter}, ConverterParameter=square}" Width="14" Height="14" />
                            <TextBlock Text="Stop" Margin="8,0,0,0" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource PrimaryWebButton}" Command="{Binding ScanCommand}">
                        <StackPanel Orientation="Horizontal">
                            <Path Style="{StaticResource LucidePath}" Data="{Binding Converter={StaticResource LucideIconConverter}, ConverterParameter=wifi}" Stroke="White" Width="14" Height="14" />
                            <TextBlock Text="{Binding ScanButtonText}" Margin="8,0,0,0" />
                        </StackPanel>
                    </Button>
                </WrapPanel>

                <Border Grid.Row="1" Margin="0,12,0,0" Background="#FFFFFF" BorderBrush="#D9E2EE" BorderThickness="1" CornerRadius="16" Padding="14,10" Visibility="{Binding HasImportedTargets, Converter={StaticResource BoolToVisible}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Width="34" Height="34" CornerRadius="12" Background="#EEF6FA">
                            <Path Style="{StaticResource LucidePath}" Data="{Binding Converter={StaticResource LucideIconConverter}, ConverterParameter=database}" Stroke="#0EA5C4" Width="16" Height="16" HorizontalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" Margin="12,0,0,0">
                            <TextBlock Text="{Binding ImportedListTitle}" FontSize="12" FontWeight="SemiBold" Foreground="#0B1020" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding ImportedListSummary}" FontSize="11" Foreground="#60708A" TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
                        </StackPanel>
                        <Border Grid.Column="2" CornerRadius="14" Background="#EEF8F6" Padding="12,5" VerticalAlignment="Center">
                            <TextBlock Text="{Binding ImportedTargetCountLabel}" FontSize="11" FontWeight="SemiBold" Foreground="#008A68" />
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="2" Margin="0,14,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid Height="3" VerticalAlignment="Center">
                        <Border Background="#EAF0F6" CornerRadius="2" />
                        <Border HorizontalAlignment="Left" Background="#28C3DE" CornerRadius="2" Width="{Binding ProgressPercent, Converter={StaticResource PercentToWidthConverter}, ConverterParameter=820}" />
                    </Grid>
                    <TextBlock Grid.Column="1" Text="{Binding ScanProgressText}" Foreground="#60708A" FontSize="10.5" Margin="14,0,0,0" VerticalAlignment="Center" />
                </Grid>
            </Grid>

            <Border Grid.Row="3" Margin="0,20,0,0" Background="#FFFFFF" BorderBrush="#D9E2EE" BorderThickness="1" CornerRadius="16" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="#FBFCFE" BorderBrush="#D9E2EE" BorderThickness="0,0,0,1">
                        <Grid Margin="18,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.8*" />
                                <ColumnDefinition Width="1.05*" />
                                <ColumnDefinition Width="1.15*" />
                                <ColumnDefinition Width="1.25*" />
                                <ColumnDefinition Width="0.8*" />
                                <ColumnDefinition Width="0.85*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="DEVICE" Style="{StaticResource ColumnHeader}" />
                            <TextBlock Grid.Column="1" Text="IP ADDRESS" Style="{StaticResource ColumnHeader}" />
                            <TextBlock Grid.Column="2" Text="EXPECTED / VENDOR" Style="{StaticResource ColumnHeader}" />
                            <TextBlock Grid.Column="3" Text="PROTOCOLS" Style="{StaticResource ColumnHeader}" />
                            <TextBlock Grid.Column="4" Text="LATENCY" Style="{StaticResource ColumnHeader}" />
                            <TextBlock Grid.Column="5" Text="STATUS" Style="{StaticResource ColumnHeader}" HorizontalAlignment="Right" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Visibility="{Binding HasVisibleDevices, Converter={StaticResource BoolToCollapsedInvert}}" VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="420">
                        <StackPanel>
                            <Border Width="54" Height="54" CornerRadius="18" Background="#EEF6FA" HorizontalAlignment="Center">
                                <Path Style="{StaticResource LucidePath}" Data="{Binding Converter={StaticResource LucideIconConverter}, ConverterParameter=network}" Stroke="#0EA5C4" Width="22" Height="22" HorizontalAlignment="Center" />
                            </Border>
                            <TextBlock Text="{Binding ScanInsightTitle}" HorizontalAlignment="Center" TextAlignment="Center" FontSize="15" FontWeight="SemiBold" Foreground="#0B1020" Margin="0,14,0,0" />
                            <TextBlock Text="{Binding ScanInsightMessage}" TextAlignment="Center" TextWrapping="Wrap" Foreground="#60708A" FontSize="12" Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>

                    <ListBox Grid.Row="1"
                             Visibility="{Binding HasVisibleDevices, Converter={StaticResource BoolToVisible}}"
                             ItemsSource="{Binding VisibleDevices}"
                             SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                             ItemContainerStyle="{StaticResource DeviceRowItem}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             VirtualizingStackPanel.IsVirtualizing="True"
                             VirtualizingStackPanel.VirtualizationMode="Recycling"
                             ScrollViewer.CanContentScroll="True">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.8*" />
                                        <ColumnDefinition Width="1.05*" />
                                        <ColumnDefinition Width="1.15*" />
                                        <ColumnDefinition Width="1.25*" />
                                        <ColumnDefinition Width="0.8*" />
                                        <ColumnDefinition Width="0.85*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="36" Height="36" CornerRadius="12" Background="#EEF2F7">
                                            <Path Style="{StaticResource LucidePath}" Data="{Binding Kind, Converter={StaticResource LucideIconConverter}}" Stroke="#172033" Width="16" Height="16" HorizontalAlignment="Center" />
                                        </Border>
                                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding HostTitle}" FontSize="12.5" FontWeight="SemiBold" Foreground="#0B1020" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding ExpectedContextLabel}" FontSize="10.5" Foreground="#60708A" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{Binding Ip}" FontFamily="Consolas, Cascadia Mono, Segoe UI Mono" FontSize="12" Foreground="#172033" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="2" Text="{Binding VendorDisplay}" FontSize="11.5" Foreground="#40516A" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="3" Text="{Binding ProtocolSummary}" FontSize="11.3" Foreground="#40516A" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="4" Text="{Binding LatencyLabel}" FontSize="11.5" Foreground="#172033" VerticalAlignment="Center" />
                                    <Border Grid.Column="5" HorizontalAlignment="Right" VerticalAlignment="Center" CornerRadius="12" Padding="9,4" Background="#EEF8F6">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="6" Height="6" Fill="{Binding Status, Converter={StaticResource StatusBrushConverter}}" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Status, Converter={StaticResource StatusLabelConverter}}" FontSize="10.5" FontWeight="SemiBold" Foreground="{Binding Status, Converter={StaticResource StatusBrushConverter}}" Margin="6,0,0,0" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Row="4" Height="{Binding DiagnosticsPanelHeight}" Margin="0,12,0,0" Background="#0A1022" CornerRadius="16" ClipToBounds="True">
                <Grid Margin="16,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Path Style="{StaticResource LucidePath}" Data="{Binding Converter={StaticResource LucideIconConverter}, ConverterParameter=activity}" Stroke="#28C3DE" Width="14" Height="14" />
                        <TextBlock Text="Diagnostics" Foreground="White" FontWeight="SemiBold" FontSize="12" Margin="22,0,0,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="{Binding ScanStateMessage}" Foreground="#C8D4E4" FontSize="11" Margin="96,0,12,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        <Button Grid.Column="2" Style="{StaticResource DarkPillButton}" Command="{Binding ClearDiagnosticsCommand}" Content="Clear" Margin="0,0,6,0" />
                        <Button Grid.Column="3" Style="{StaticResource DarkPillButton}" Command="{Binding ToggleDiagnosticsCommand}" Content="{Binding DiagnosticsToggleText}" />
                    </Grid>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Diagnostics}" Background="Transparent" BorderThickness="0" Foreground="#E2E8F0" ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="58" />
                                        <ColumnDefinition Width="78" />
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" FontSize="10.5" Foreground="#94A3B8" />
                                    <TextBlock Grid.Column="1" Text="{Binding Severity}" FontSize="10.5" Foreground="#7DD3FC" />
                                    <TextBlock Grid.Column="2" Text="{Binding Source}" FontSize="10.5" Foreground="#CBD5E1" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="3" Text="{Binding Message}" FontSize="10.5" Foreground="#E2E8F0" TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="1" Grid.Column="1" Background="#FFFFFF" BorderBrush="#D9E2EE" BorderThickness="1,0,0,0">
            <Grid Margin="22,24,22,22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Text="DEVICE DETAILS" Style="{StaticResource SectionLabel}" />
                <Grid Grid.Row="1">
                    <StackPanel Visibility="{Binding SelectedDevice, Converter={StaticResource NullToCollapsedInvert}}" VerticalAlignment="Center">
                        <Border Width="54" Height="54" CornerRadius="18" Background="#EEF2F7" HorizontalAlignment="Center">
                            <Path Style="{StaticResource LucidePath}" Data="{Binding Converter={StaticResource LucideIconConverter}, ConverterParameter=server}" Stroke="#60708A" Width="22" Height="22" HorizontalAlignment="Center" />
                        </Border>
                        <TextBlock Text="Select a device" HorizontalAlignment="Center" FontSize="13" FontWeight="SemiBold" Foreground="#0B1020" Margin="0,12,0,0" />
                        <TextBlock Text="Pick a row to inspect identity, ports and fingerprint." TextWrapping="Wrap" TextAlignment="Center" Foreground="#60708A" FontSize="11.5" Margin="0,6,0,0" />
                    </StackPanel>

                    <ScrollViewer Visibility="{Binding SelectedDevice, Converter={StaticResource NullToVisible}}" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="54" Height="54" CornerRadius="18" Background="#EEF2F7">
                                    <Path Style="{StaticResource LucidePath}" Data="{Binding SelectedDevice.Kind, Converter={StaticResource LucideIconConverter}}" Stroke="#172033" Width="22" Height="22" HorizontalAlignment="Center" />
                                </Border>
                                <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SelectedDevice.HostTitle}" FontSize="15" FontWeight="SemiBold" Foreground="#0B1020" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding SelectedDevice.KindLabel}" FontSize="11" Foreground="#60708A" />
                                </StackPanel>
                            </StackPanel>

                            <Border HorizontalAlignment="Left" CornerRadius="12" Padding="10,5" Background="#EEF8F6" Margin="0,16,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="6" Height="6" Fill="{Binding SelectedDevice.Status, Converter={StaticResource StatusBrushConverter}}" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding SelectedDevice.Status, Converter={StaticResource StatusLabelConverter}}" FontSize="10.5" FontWeight="SemiBold" Foreground="{Binding SelectedDevice.Status, Converter={StaticResource StatusBrushConverter}}" Margin="6,0,0,0" />
                                </StackPanel>
                            </Border>

                            <StackPanel Margin="0,18,0,0" Visibility="{Binding SelectedDevice.IsExpectedTarget, Converter={StaticResource BoolToVisible}}">
                                <TextBlock Text="EXPECTED TARGET" Style="{StaticResource SectionLabel}" />
                                <Border Background="#F8FBFF" BorderBrush="#D9E2EE" BorderThickness="1" CornerRadius="16" Padding="14,12">
                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectedDevice.ExpectedDeviceName}" FontSize="12" FontWeight="SemiBold" Foreground="#0B1020" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding SelectedDevice.ExpectedContextLabel}" FontSize="11" Foreground="#60708A" Margin="0,4,0,0" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding SelectedDevice.Remark}" FontSize="10.5" Foreground="#60708A" Margin="0,6,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Margin="0,20,0,0">
                                <Grid Height="30">
                                    <TextBlock Text="IP ADDRESS" Foreground="#60708A" FontSize="10.5" VerticalAlignment="Center" />
                                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" Text="{Binding SelectedDevice.Ip}" FontFamily="Consolas" FontSize="11.5" Foreground="#0B1020" />
                                </Grid>
                                <Border Height="1" Background="#D9E2EE" />
                                <Grid Height="30">
                                    <TextBlock Text="MAC" Foreground="#60708A" FontSize="10.5" VerticalAlignment="Center" />
                                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" Text="{Binding SelectedDevice.MacAddress, TargetNullValue=-}" FontFamily="Consolas" FontSize="11" Foreground="#0B1020" />
                                </Grid>
                                <Border Height="1" Background="#D9E2EE" />
                                <Grid Height="30">
                                    <TextBlock Text="VENDOR" Foreground="#60708A" FontSize="10.5" VerticalAlignment="Center" />
                                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" Text="{Binding SelectedDevice.VendorDisplay}" FontSize="11.5" Foreground="#0B1020" TextTrimming="CharacterEllipsis" MaxWidth="178" />
                                </Grid>
                                <Border Height="1" Background="#D9E2EE" />
                                <Grid Height="30">
                                    <TextBlock Text="LATENCY" Foreground="#60708A" FontSize="10.5" VerticalAlignment="Center" />
                                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" Text="{Binding SelectedDevice.LatencyLabel}" FontSize="11.5" Foreground="#0B1020" />
                                </Grid>
                                <Border Height="1" Background="#D9E2EE" />
                                <Grid Height="30">
                                    <TextBlock Text="LAST SEEN" Foreground="#60708A" FontSize="10.5" VerticalAlignment="Center" />
                                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" Text="{Binding SelectedDevice.LastSeen, StringFormat={}{0:HH:mm:ss}}" FontSize="11.5" Foreground="#0B1020" />
                                </Grid>
                                <Border Height="1" Background="#D9E2EE" />
                                <Grid Height="30">
                                    <TextBlock Text="STAGE" Foreground="#60708A" FontSize="10.5" VerticalAlignment="Center" />
                                    <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" Text="{Binding SelectedDevice.ProbeStage}" FontSize="11.5" Foreground="#0B1020" TextTrimming="CharacterEllipsis" MaxWidth="178" />
                                </Grid>
                            </StackPanel>

                            <StackPanel Margin="0,20,0,0" Visibility="{Binding SelectedDevice.HasOpenPorts, Converter={StaticResource BoolToVisible}}">
                                <TextBlock Text="OPEN PORTS" Style="{StaticResource SectionLabel}" />
                                <ItemsControl ItemsSource="{Binding SelectedDevice.OpenPorts}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="10" Padding="8,4" Margin="0,0,6,6" Background="#E8F8FC" BorderBrush="#CBEFF6" BorderThickness="1">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Port}" FontWeight="SemiBold" FontSize="11" Foreground="#0A96B5" />
                                                    <TextBlock Text=" " />
                                                    <TextBlock Text="{Binding Label}" FontSize="11" Foreground="#0A96B5" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <StackPanel Margin="0,14,0,0">
                                <TextBlock Text="FINGERPRINT" Style="{StaticResource SectionLabel}" />
                                <TextBlock Text="{Binding SelectedDevice.ProtocolSummary}" TextWrapping="Wrap" Foreground="#172033" FontSize="11.5" />
                                <TextBlock Text="{Binding SelectedDevice.Evidence}" TextWrapping="Wrap" Foreground="#60708A" FontSize="11" Margin="0,5,0,0" />
                            </StackPanel>

                            <Button Style="{StaticResource AccentWebButton}" Command="{Binding CopyIpCommand}" Height="38" Margin="0,22,0,0" HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource LucidePath}" Data="{Binding Converter={StaticResource LucideIconConverter}, ConverterParameter=copy}" Stroke="White" Width="14" Height="14" />
                                    <TextBlock Text="Copy IP" Margin="8,0,0,0" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
