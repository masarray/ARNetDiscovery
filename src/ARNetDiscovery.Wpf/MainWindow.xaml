        <Border Grid.Row="1" Grid.Column="2" Width="{Binding InspectorPanelWidth}" Background="#F9FBFD" BorderBrush="#DCE4EF" BorderThickness="1,0,0,0" MouseLeftButtonUp="InspectorPanel_MouseLeftButtonUp">
