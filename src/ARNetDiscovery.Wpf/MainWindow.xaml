                </Grid>
            </Border>

            <Border Grid.Row="2" Background="#FFFFFF" BorderBrush="#DCE5EE" BorderThickness="1" CornerRadius="0" ClipToBounds="False" Effect="{StaticResource ShadowSoft}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Background="#FAFCFE" BorderBrush="#E7EDF4" BorderThickness="0,0,0,1" Padding="18,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.75*" />
