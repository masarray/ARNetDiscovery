                                    <TextBlock Grid.Column="2" Text="{Binding Source}" FontSize="10.5" Foreground="#CBD5E1" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="3" Text="{Binding Message}" FontSize="10.5" Foreground="#E2E8F0" TextTrimming="CharacterEllipsis" />
                                </Grid>
