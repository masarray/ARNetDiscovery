                        </Grid.ColumnDefinitions>
                        <Border Width="26" Height="26" CornerRadius="9" Background="#E8F7FB" BorderBrush="#C8EEF6" BorderThickness="1" VerticalAlignment="Center">
                            <Path Style="{StaticResource MaterialIcon}" Data="{Binding Converter={StaticResource MaterialIconConverter}, ConverterParameter=bug_report}" Fill="#0EA5C4" Width="14" Height="14" />
                        </Border>
                        <TextBlock Grid.Column="1" Text="Diagnostics" Foreground="#0B1020" FontWeight="SemiBold" FontSize="12" Margin="9,0,16,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{Binding ScanStateMessage}" Foreground="#52657A" FontSize="11" Margin="0,0,12,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        <Button Grid.Column="3" Style="{StaticResource DiagnosticsClearButton}" Command="{Binding ClearDiagnosticsCommand}" Content="Clear" />
                        <Button Grid.Column="4" Style="{StaticResource InspectorChevronButton}" Command="{Binding ToggleDiagnosticsCommand}" Visibility="{Binding IsDiagnosticsExpanded, Converter={StaticResource BoolToCollapsedInvert}}" ToolTip="Expand diagnostics">
                            <Path Style="{StaticResource MaterialIcon}" Data="{Binding Converter={StaticResource MaterialIconConverter}, ConverterParameter=chevron_circle_up}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="20" Height="20" />
                        </Button>
                        <Button Grid.Column="4" Style="{StaticResource InspectorChevronButton}" Command="{Binding ToggleDiagnosticsCommand}" Visibility="{Binding IsDiagnosticsExpanded, Converter={StaticResource BoolToVisible}}" ToolTip="Collapse diagnostics">
                            <Path Style="{StaticResource MaterialIcon}" Data="{Binding Converter={StaticResource MaterialIconConverter}, ConverterParameter=chevron_circle_down}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="20" Height="20" />
                        </Button>
                    </Grid>
                    <ListBox Grid.Row="1" ItemsSource="{Binding Diagnostics}" Background="Transparent" BorderThickness="0" Foreground="#172033" ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="58" />
                                        <ColumnDefinition Width="78" />
                                        <ColumnDefinition Width="130" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss}}" FontSize="10.5" Foreground="#64748B" />
                                    <TextBlock Grid.Column="1" Text="{Binding Severity}" FontSize="10.5" Foreground="#0EA5C4" />
                                    <TextBlock Grid.Column="2" Text="{Binding Source}" FontSize="10.5" Foreground="#334155" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="3" Text="{Binding Message}" FontSize="10.5" Foreground="#0F172A" TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="1" Grid.Column="1"
                Width="{Binding InspectorPanelWidth}"
                Margin="0,0,18,18"
                Background="{StaticResource SurfacePropertiesBrush}"
                BorderBrush="#C9D8E6"
                BorderThickness="1"
                CornerRadius="20"
                Effect="{StaticResource ShadowSoft}"
                MouseLeftButtonUp="InspectorPanel_MouseLeftButtonUp">
            <Grid>
                <Button Style="{StaticResource InspectorChevronButton}"
                        Command="{Binding ToggleInspectorCommand}"
                        ToolTip="{Binding InspectorToggleToolTip}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,20,0,0"
                        Visibility="{Binding IsInspectorExpanded, Converter={StaticResource BoolToCollapsedInvert}}">
                    <Path Style="{StaticResource MaterialIcon}" Data="{Binding Converter={StaticResource MaterialIconConverter}, ConverterParameter=chevron_circle_left}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="22" Height="22" />
                </Button>
                <Grid Margin="22,22,22,20" Visibility="{Binding IsInspectorExpanded, Converter={StaticResource BoolToVisible}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid Cursor="Hand" MouseLeftButtonUp="InspectorHeader_MouseLeftButtonUp">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Properties" FontSize="18" FontWeight="SemiBold" Foreground="#0B1020" />
                        <TextBlock Text="Selected device evidence" FontSize="11" Foreground="#60708A" Margin="0,3,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1" Style="{StaticResource InspectorChevronButton}" Command="{Binding ToggleInspectorCommand}" ToolTip="{Binding InspectorToggleToolTip}">
                        <Path Style="{StaticResource MaterialIcon}" Data="{Binding Converter={StaticResource MaterialIconConverter}, ConverterParameter=chevron_circle_right}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="22" Height="22" />
                    </Button>
                </Grid>

                <Grid Grid.Row="1" Margin="0,18,0,0">
                    <StackPanel Visibility="{Binding SelectedDevice, Converter={StaticResource NullToCollapsedInvert}}" VerticalAlignment="Center">
                        <Border Width="66" Height="66" CornerRadius="18" Background="#EAF8FC" HorizontalAlignment="Center">
                            <Path Style="{StaticResource MaterialIcon}" Data="{Binding Converter={StaticResource MaterialIconConverter}, ConverterParameter=devices}" Fill="#0EA5C4" Width="28" Height="28" />
                        </Border>
                        <TextBlock Text="Select a device" HorizontalAlignment="Center" FontSize="14" FontWeight="SemiBold" Foreground="#0B1020" Margin="0,14,0,0" />
                        <TextBlock Text="Pick a row to inspect expected identity, protocol evidence, ports and diagnostics." TextWrapping="Wrap" TextAlignment="Center" Foreground="#60708A" FontSize="11.5" Margin="0,7,0,0" />
                    </StackPanel>

                    <ScrollViewer Visibility="{Binding SelectedDevice, Converter={StaticResource NullToVisible}}" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Background="{StaticResource SurfacePropertiesCardBrush}" BorderBrush="#D1E0EC" BorderThickness="1" CornerRadius="18" Padding="16" Effect="{StaticResource ShadowSoft}">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="58" Height="58" CornerRadius="16" Background="{Binding SelectedDevice, Converter={StaticResource DeviceIconBrushConverter}}" BorderBrush="#D7E3EF" BorderThickness="1">
                                            <Path Style="{StaticResource MaterialIcon}" Data="{Binding SelectedDevice, Converter={StaticResource MaterialIconConverter}}" Fill="{Binding SelectedDevice, Converter={StaticResource DeviceIconBrushConverter}, ConverterParameter=Foreground}" Width="24" Height="24" />
                                        </Border>
                                        <StackPanel Margin="13,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding SelectedDevice.HostTitle}" FontSize="15" FontWeight="SemiBold" Foreground="#0B1020" TextTrimming="CharacterEllipsis" MaxWidth="240" />
                                            <TextBlock Text="{Binding SelectedDevice.KindLabel}" FontSize="11" Foreground="#60708A" TextTrimming="CharacterEllipsis" MaxWidth="240" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Border HorizontalAlignment="Left" CornerRadius="13" Padding="10,5" Background="#F5FBFA" BorderBrush="#DCEFEA" BorderThickness="1" Margin="0,15,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="6" Height="6" Fill="{Binding SelectedDevice.Status, Converter={StaticResource StatusBrushConverter}}" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding SelectedDevice.Status, Converter={StaticResource StatusLabelConverter}}" FontSize="10.5" FontWeight="SemiBold" Foreground="{Binding SelectedDevice.Status, Converter={StaticResource StatusBrushConverter}}" Margin="6,0,0,0" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource SurfacePropertiesCardBrush}" BorderBrush="#D1E0EC" BorderThickness="1" CornerRadius="16" Padding="15" Margin="0,12,0,0" Visibility="{Binding SelectedDevice.IsExpectedTarget, Converter={StaticResource BoolToVisible}}">
                                <StackPanel>
                                    <TextBlock Text="EXPECTED TARGET" Style="{StaticResource SectionLabel}" />
                                    <TextBlock Text="{Binding SelectedDevice.ExpectedDeviceName}" FontSize="12.3" FontWeight="SemiBold" Foreground="#0B1020" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding SelectedDevice.ExpectedContextLabel}" FontSize="11" Foreground="#60708A" Margin="0,5,0,0" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding SelectedDevice.Remark}" FontSize="10.5" Foreground="#60708A" Margin="0,6,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource SurfacePropertiesCardBrush}" BorderBrush="#D1E0EC" BorderThickness="1" CornerRadius="16" Padding="15" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="NETWORK EVIDENCE" Style="{StaticResource SectionLabel}" />
                                    <Grid Height="30">
                                        <TextBlock Text="IP ADDRESS" Foreground="#60708A" FontSize="10.5" VerticalAlignment="Center" />
                                        <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" Text="{Binding SelectedDevice.Ip}" FontFamily="Consolas" FontSize="11.5" Foreground="#0B1020" />
                                    </Grid>
                                    <Border Height="1" Background="#E7EDF4" />
                                    <Grid Height="30">
                                        <TextBlock Text="MAC" Foreground="#60708A" FontSize="10.5" VerticalAlignment="Center" />
                                        <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" Text="{Binding SelectedDevice.MacAddress, TargetNullValue=-}" FontFamily="Consolas" FontSize="11" Foreground="#0B1020" />
                                    </Grid>
                                    <Border Height="1" Background="#E7EDF4" />
                                    <Grid Height="30">
                                        <TextBlock Text="VENDOR" Foreground="#60708A" FontSize="10.5" VerticalAlignment="Center" />
                                        <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" Text="{Binding SelectedDevice.VendorDisplay}" FontSize="11.5" Foreground="#0B1020" TextTrimming="CharacterEllipsis" MaxWidth="215" />
                                    </Grid>
                                    <Border Height="1" Background="#E7EDF4" />
                                    <Grid Height="30">
                                        <TextBlock Text="LATENCY" Foreground="#60708A" FontSize="10.5" VerticalAlignment="Center" />
                                        <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" Text="{Binding SelectedDevice.LatencyLabel}" FontSize="11.5" Foreground="#0B1020" />
                                    </Grid>
                                    <Border Height="1" Background="#E7EDF4" />
                                    <Grid Height="30">
                                        <TextBlock Text="LAST SEEN" Foreground="#60708A" FontSize="10.5" VerticalAlignment="Center" />
                                        <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" Text="{Binding SelectedDevice.LastSeen, StringFormat={}{0:HH:mm:ss}}" FontSize="11.5" Foreground="#0B1020" />
                                    </Grid>
                                    <Border Height="1" Background="#E7EDF4" />
                                    <Grid Height="30">
                                        <TextBlock Text="STAGE" Foreground="#60708A" FontSize="10.5" VerticalAlignment="Center" />
                                        <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center" Text="{Binding SelectedDevice.ProbeStage}" FontSize="11.5" Foreground="#0B1020" TextTrimming="CharacterEllipsis" MaxWidth="215" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource SurfacePropertiesCardBrush}" BorderBrush="#D1E0EC" BorderThickness="1" CornerRadius="16" Padding="15" Margin="0,12,0,0" Visibility="{Binding SelectedDevice.HasOpenPorts, Converter={StaticResource BoolToVisible}}">
                                <StackPanel>
                                    <TextBlock Text="OPEN PORTS" Style="{StaticResource SectionLabel}" />
                                    <ItemsControl ItemsSource="{Binding SelectedDevice.OpenPorts}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="10" Padding="8,4" Margin="0,0,6,6" Background="#E8F8FC" BorderBrush="#CBEFF6" BorderThickness="1">
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Port}" FontWeight="SemiBold" FontSize="11" Foreground="#0A96B5" />
                                                        <TextBlock Text=" " />
                                                        <TextBlock Text="{Binding Label}" FontSize="11" Foreground="#0A96B5" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>

                            <Border Background="{StaticResource SurfacePropertiesCardBrush}" BorderBrush="#D1E0EC" BorderThickness="1" CornerRadius="16" Padding="15" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="FINGERPRINT" Style="{StaticResource SectionLabel}" />
                                    <TextBlock Text="{Binding SelectedDevice.ProtocolSummary}" TextWrapping="Wrap" Foreground="#172033" FontSize="11.6" />
                                    <TextBlock Text="{Binding SelectedDevice.Evidence}" TextWrapping="Wrap" Foreground="#60708A" FontSize="11" Margin="0,7,0,0" />
                                </StackPanel>
                            </Border>

                            <Button Style="{StaticResource AccentButton}" Command="{Binding CopyIpCommand}" Height="42" Margin="0,14,0,0" HorizontalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal">
                                    <Path Style="{StaticResource MaterialIcon}" Data="{Binding Converter={StaticResource MaterialIconConverter}, ConverterParameter=content_copy}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="15" Height="15" />
                                    <TextBlock Text="Copy IP Address" Margin="8,0,0,0" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
