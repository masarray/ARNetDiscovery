<Window x:Class="ARNetDiscovery.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:conv="clr-namespace:ARNetDiscovery.Wpf.Converters"
        mc:Ignorable="d"
        Title="ARNet Discovery"
        Icon="pack://application:,,,/Resources/app-icon.ico"
        Width="1800" Height="830" MinWidth="1120" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        Background="#F5F7FA"
        Topmost="{Binding IsAlwaysOnTop}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <conv:StatusBrushConverter x:Key="StatusBrushConverter" />
        <conv:NullToVisibilityConverter x:Key="NullToVisible" />
        <conv:NullToVisibilityConverter x:Key="NullToCollapsedInvert" Invert="True" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVisible" />
        <conv:BoolToVisibilityConverter x:Key="BoolToCollapsedInvert" Invert="True" />
        <conv:StringEmptyToVisibilityConverter x:Key="StringEmptyToVisible" />
        <conv:StringEmptyToVisibilityConverter x:Key="StringNotEmptyToVisible" Invert="True" />
        <conv:MaterialIconConverter x:Key="MaterialIconConverter" />
        <conv:DeviceIconBrushConverter x:Key="DeviceIconBrushConverter" />
        <conv:StatusLabelConverter x:Key="StatusLabelConverter" />

        <LinearGradientBrush x:Key="ShellBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F8FAFC" Offset="0" />
            <GradientStop Color="#F2F6FA" Offset="0.55" />
            <GradientStop Color="#EEF4F8" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SurfaceControlBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0" />
            <GradientStop Color="#F8FCFE" Offset="0.58" />
            <GradientStop Color="#EEF9FC" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SurfaceTableBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0" />
            <GradientStop Color="#FAFCFE" Offset="0.62" />
            <GradientStop Color="#F2F6FA" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SurfaceDiagnosticsBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0" />
            <GradientStop Color="#F8FCFB" Offset="0.54" />
            <GradientStop Color="#F1FAF8" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SurfacePropertiesBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0" />
            <GradientStop Color="#FAFCFF" Offset="0.55" />
            <GradientStop Color="#F1F7FD" Offset="1" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="SurfacePropertiesCardBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFFFF" Offset="0" />
            <GradientStop Color="#F9FCFD" Offset="0.68" />
            <GradientStop Color="#F2FBFC" Offset="1" />
        </LinearGradientBrush>


        <DropShadowEffect x:Key="ShadowSoft" Color="#12304A" BlurRadius="18" ShadowDepth="4" Direction="270" Opacity="0.075" />
        <DropShadowEffect x:Key="ShadowLift" Color="#12304A" BlurRadius="24" ShadowDepth="6" Direction="270" Opacity="0.11" />
        <DropShadowEffect x:Key="ShadowButton" Color="#12304A" BlurRadius="10" ShadowDepth="2" Direction="270" Opacity="0.065" />

        <Style x:Key="MaterialIcon" TargetType="Path">
            <Setter Property="Width" Value="17" />
            <Setter Property="Height" Value="17" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="Fill" Value="#40516A" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="WindowIconButton" TargetType="Button">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" CornerRadius="10" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EEF3F8" />
                                <Setter Property="Foreground" Value="#0B1020" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseWindowButton" TargetType="Button" BasedOn="{StaticResource WindowIconButton}">
            <Setter Property="Foreground" Value="#64748B" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White" />
                    <Setter Property="Background" Value="#EF4444" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RailIconButton" TargetType="Button">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="0,5" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#8B9AB0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Root" CornerRadius="13" Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EEF6FA" />
                                <Setter Property="Foreground" Value="#0B1020" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.72" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RailIconButtonActive" TargetType="Button" BasedOn="{StaticResource RailIconButton}">
            <Setter Property="Foreground" Value="#0EA5C4" />
            <Setter Property="Background" Value="#E9F8FC" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border CornerRadius="13" Background="#E8F7FB" BorderBrush="#C8EEF6" BorderThickness="1">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PremiumButton" TargetType="Button">
            <Setter Property="Height" Value="40" />
            <Setter Property="MinWidth" Value="112" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#CCD7E3" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                SnapsToDevicePixels="True"
                                Effect="{StaticResource ShadowButton}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,0" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#9FB2C8" />
                                <Setter TargetName="Root" Property="Opacity" Value="0.96" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.84" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#2EC4E6" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.46" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryDarkButton" TargetType="Button" BasedOn="{StaticResource PremiumButton}">
            <Setter Property="Background" Value="#087C92" />
            <Setter Property="BorderBrush" Value="#087C92" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="18,0" />
        </Style>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource PremiumButton}">
            <Setter Property="Background" Value="#0EA5C4" />
            <Setter Property="BorderBrush" Value="#0788A0" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Padding" Value="18,0" />
        </Style>

        <Style x:Key="SoftDangerButton" TargetType="Button" BasedOn="{StaticResource PremiumButton}">
            <Setter Property="Background" Value="#FFF1F2" />
            <Setter Property="BorderBrush" Value="#FFD6DA" />
            <Setter Property="Foreground" Value="#D12F3C" />
        </Style>

        <Style x:Key="TinyIconButton" TargetType="Button" BasedOn="{StaticResource PremiumButton}">
            <Setter Property="MinWidth" Value="108" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Padding" Value="16,0" />
        </Style>

        <Style x:Key="DiagnosticsClearButton" TargetType="Button" BasedOn="{StaticResource PremiumButton}">
            <Setter Property="MinWidth" Value="54" />
            <Setter Property="Width" Value="54" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#CCD7E3" />
            <Setter Property="Foreground" Value="#0F172A" />
            <Setter Property="FontSize" Value="11" />
        </Style>

        <Style x:Key="ChevronIconButton" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#23BDD8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="Transparent" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#10243A" />
                                <Setter Property="Foreground" Value="#7DD3FC" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.70" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InspectorChevronButton" TargetType="Button" BasedOn="{StaticResource ChevronIconButton}">
            <Setter Property="Foreground" Value="#0EA5C4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="Transparent" CornerRadius="15">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#E9F8FC" />
                                <Setter Property="Foreground" Value="#0788A0" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.70" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PremiumComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Foreground" Value="#172033" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent"
                                          BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <ContentPresenter />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <Border x:Name="Box" Height="40" Background="#FFFFFF" BorderBrush="#CCD7E3" BorderThickness="1" CornerRadius="13">
                                    <Grid>
                                        <ContentPresenter Margin="14,0,34,0"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Left"
                                                          IsHitTestVisible="False"
                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" />
                                        <Path Data="M7,10L12,15L17,10H7Z" Fill="#64748B" Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Right" Margin="0,0,13,0" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="280"
                                        Margin="0,8,0,0"
                                        Background="White"
                                        BorderBrush="#CCD7E3"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="6"
                                        ClipToBounds="True"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer CanContentScroll="True">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="#9FB2C8" />
                                <Setter TargetName="Box" Property="Background" Value="#FCFEFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Box" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#172033" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemRoot" CornerRadius="10" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#EEF8FB" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="#E6F7FC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CleanTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="40" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Foreground" Value="#172033" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <Style x:Key="ColumnHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#52657A" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="TableHeaderButton" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#52657A" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="8" Padding="0,0,6,0">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#EEF6FA" />
                                <Setter Property="Foreground" Value="#0B1020" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="0.76" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ColumnResizeSplitter" TargetType="GridSplitter">
            <Setter Property="Width" Value="8" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="ResizeDirection" Value="Columns" />
            <Setter Property="ResizeBehavior" Value="PreviousAndNext" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="ShowsPreview" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="GridSplitter">
                        <Grid Background="Transparent">
                            <Border x:Name="Rail" Width="1" HorizontalAlignment="Center" Background="#D5E0EA" Opacity="0.42" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Rail" Property="Background" Value="#0EA5C4" />
                                <Setter TargetName="Rail" Property="Opacity" Value="0.9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#52657A" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="DeviceRowItem" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="BorderBrush" Value="#E7EDF4" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Margin="18,10" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#F5F9FC" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#D5E2ED" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#E8F7FB" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="#B9EAF4" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#2EC4E6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#F7FAFD" />
                </Trigger>
            </Style.Triggers>
        </Style>


        <Style x:Key="SlimScrollThumb" TargetType="Thumb">
            <Setter Property="MinHeight" Value="42" />
            <Setter Property="MaxHeight" Value="168" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="MaxWidth" Value="168" />
            <Setter Property="Opacity" Value="0.78" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Grid Background="Transparent">
                            <Border x:Name="ThumbRail"
                                    Width="6"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Stretch"
                                    Background="#B8C6D8"
                                    CornerRadius="3"
                                    Margin="0" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Tag" Value="Horizontal">
                                <Setter Property="MinHeight" Value="0" />
                                <Setter Property="MinWidth" Value="42" />
                                <Setter TargetName="ThumbRail" Property="Width" Value="Auto" />
                                <Setter TargetName="ThumbRail" Property="Height" Value="6" />
                                <Setter TargetName="ThumbRail" Property="Margin" Value="0" />
                                <Setter TargetName="ThumbRail" Property="VerticalAlignment" Value="Center" />
                                <Setter TargetName="ThumbRail" Property="HorizontalAlignment" Value="Stretch" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbRail" Property="Background" Value="#8EA0B8" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbRail" Property="Background" Value="#6F829E" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.96" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ScrollBarLineButton" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Stylus.IsFlicksEnabled" Value="False" />
            <Setter Property="Foreground" Value="#B8C6D8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Width" Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="GridRoot" Width="10" Background="Transparent">
                            <Track x:Name="PART_Track" Margin="0,7" IsDirectionReversed="True" Focusable="False">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarLineButton}" Command="ScrollBar.PageUpCommand" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb x:Name="Thumb" Style="{StaticResource SlimScrollThumb}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollBarLineButton}" Command="ScrollBar.PageDownCommand" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
