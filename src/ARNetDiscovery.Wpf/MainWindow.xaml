                                    <TextBlock Grid.Column="3" Text="{Binding ProtocolSummary}" FontSize="11.2" Foreground="#40516A" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="4" Text="{Binding LatencyLabel}" FontSize="11.4" Foreground="#172033" VerticalAlignment="Center" />
