                                <Path Style="{StaticResource MaterialIcon}" Data="{Binding Converter={StaticResource MaterialIconConverter}, ConverterParameter=hub}" Fill="#0EA5C4" Width="26" Height="26" />
                            </Border>
                            <TextBlock Text="{Binding ScanInsightTitle}" HorizontalAlignment="Center" TextAlignment="Center" FontSize="16" FontWeight="SemiBold" Foreground="#0B1020" Margin="0,16,0,0" />
                            <TextBlock Text="{Binding ScanAdvice}" TextAlignment="Center" TextWrapping="Wrap" Foreground="#60708A" FontSize="12" Margin="0,8,0,0" />
