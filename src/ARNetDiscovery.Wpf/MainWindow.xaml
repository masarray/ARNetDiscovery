                    </Border>

                    <Border Grid.Row="1" Visibility="{Binding HasVisibleDevices, Converter={StaticResource BoolToCollapsedInvert}}" VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="520" Padding="24">
